GEMINI_API_KEY=your_gemini_api_key_here
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# Optional AI network settings.
# Use this if Gemini/DeepSeek/OpenAI needs your local proxy.
# AI_PROXY=http://127.0.0.1:7890

# Use this if stale system proxy variables break AI requests.
# AI_USE_SYSTEM_PROXY=false

# Optional public web-news search settings.
# If omitted, web news search reuses AI_PROXY.
# NEWS_SEARCH_PROXY=http://127.0.0.1:7890
# Set true only if your system HTTP_PROXY/HTTPS_PROXY/ALL_PROXY is correct.
# NEWS_SEARCH_USE_SYSTEM_PROXY=false
